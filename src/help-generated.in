// -*- mode: rust -*-
//
// Generated by `cargo xtask gen-help` (run `make help`). Do not edit by hand.
// The help text is written in Markdown in `src/help/*.md`: the lead
// paragraph is the short `about`, the rest is the long `long_about`.

const HELP_ABOUT: &str = "\u{1b}[1m\u{1b}[34mName:\u{1b}[39m\u{1b}[22m\n  rig {version} - manage R installations\n\n\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  rig manages your R installations, on macOS, Windows, and Linux. It can\n  install and set up multiple versions of R, and make sure that they work\n  together.\n\n  rig is under constant development. Feedback is much appreciated.\n  See https://github.com/r-lib/rig for bug reports.";
const ABOUT_ADD: &str = "Install a new R version [alias: install]";
const HELP_ADD: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Download and install an R version, from the official sources. It keeps\n  the already installed R versions, except on macOS in admin mode, where\n  patch versions of the same minor overwrite each other.\n\n  On macOS and Windows rig uses the R builds at https://cran.r-project.org.\n  On Linux rig uses the Posit R builds from\n  https://github.com/rstudio/r-builds.\n\n  On Linux, in user mode rig always installs a portable build, selected for\n  your C library (glibc or musl). In admin mode rig installs a\n  distro-specific build by default, but you can install a portable build\n  instead with \u{1b}[32m--platform linux-portable\u{1b}[39m (or a specific portable platform,\n  e.g. \u{1b}[32m--platform linux-manylinux-2.34\u{1b}[39m). If there is no distro-specific\n  build for your platform, rig falls back to a portable build automatically.\n  Admin-mode portable builds are installed into \u{1b}[32m/opt/R/<version>\u{1b}[39m, just like\n  distro-specific builds.\n\n  The desired R version can be specified in various ways:\n\n  - \u{1b}[32mrig add devel\u{1b}[39m adds the latest available development version,\n  - \u{1b}[32mrig add next\u{1b}[39m is the next version (patched, alpha, beta, rc, etc.),\n  - \u{1b}[32mrig add release\u{1b}[39m adds the latest release.\n  - \u{1b}[32mrig add x.y.z\u{1b}[39m adds a specific version.\n  - \u{1b}[32mrig add x.y\u{1b}[39m adds the latest release within the \u{1b}[32mx.y\u{1b}[39m minor branch.\n  - \u{1b}[32mrig add oldrel/n\u{1b}[39m adds the latest release within the \u{1b}[32mn\u{1b}[39mth previous\n    minor branch (\u{1b}[32moldrel\u{1b}[39m is the same as \u{1b}[32moldrel/1\u{1b}[39m).\n  - \u{1b}[32mrig add <url>\u{1b}[39m uses a build from \u{1b}[32m<url>\u{1b}[39m.\n\n  In user mode rig installs R into your home directory and never needs\n  \u{1b}[32msudo\u{1b}[39m. In admin mode you usually need to run this command with \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig add ...\u{1b}[39m, otherwise rig will need to ask for your password.\n\n  In admin mode on macOS rig cannot add multiple R versions from the same\n  minor branch. E.g. it is not possible to have R 4.6.0 and R 4.6.1\n  installed at the same time. Adding one of them will automatically remove\n  the other. In user mode there is no such restriction.\n\n  You can use \u{1b}[32mrig add\u{1b}[39m to install Rtools:\n\n  rig add rtools\n\n  will install all Rtools versions that are needed for the currently\n  installed R versions. You can also request a specific Rtools version,\n  e.g. \u{1b}[32mrig add rtools45\u{1b}[39m.\n\n  In user mode rig installs R and Rtools into your user profile, without\n  administrator rights. In admin mode you need an administrator account to\n  run this command.\n\n\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  # Add the latest development snapshot\n  rig add devel\n\n  # Add the latest release\n  rig add release\n\n  # Install specific version\n  rig add 4.6.1\n\n  # Install latest version within a minor branch\n  rig add 4.6\n\n  # Install arm64 build of R (default on arm64 machines)\n  rig add -a arm64 release\n\n  # Install x86_64 build of R (default on x86_64 machines)\n  rig add -a x86_64 release\n\n  # Install all needed Rtools versions (Windows only)\n  rig add rtools";
const ABOUT_AVAILABLE: &str = "List R versions available to install.";
const HELP_AVAILABLE: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List R versions available to install.\n\n  By default some releases are omitted from the output:\n\n  - Versions older than R 3.0.0 are omitted. The installation of these\n    might not work at all.\n  - Only the latest release is shown for each minor version. E.g.\n    R 4.2.3 is listed, but other R 4.2.x versions are not.\n    Use \u{1b}[32m--all\u{1b}[39m to list all versions.\n\n  Use \u{1b}[32m--json\u{1b}[39m to return the output in JSON. JSON output includes the\n  full time stamp (if available) and the download URL as well.\n\n  With the \u{1b}[32m--list-distros\u{1b}[39m flag it lists supported Linux distributions.\n\n  With the \u{1b}[32m--list-rtools-versions\u{1b}[39m flag it lists supported Rtools versions.\n  Rtools contains tools to build R and R packages on Windows.\n  Use \u{1b}[32m--all\u{1b}[39m to list all Rtools versions, even very old ones.";
const ABOUT_CONFIG_CONFIG_FILE_PATH: &str = "Print the path to the rig config file";
const HELP_CONFIG_CONFIG_FILE_PATH: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Print the full path to the rig configuration file.\n\n  The file might not exist yet; rig creates it when you first set an entry\n  with \u{1b}[32mrig config set\u{1b}[39m.";
const ABOUT_CONFIG_GET: &str = "Get a config entry";
const HELP_CONFIG_GET: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Print the value of a rig configuration entry.\n\n  Configuration keys are listed by \u{1b}[32mrig config list\u{1b}[39m.";
const ABOUT_CONFIG_LIST: &str = "List the names of all config entries";
const HELP_CONFIG_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List the names of all rig configuration entries.\n\n  Use \u{1b}[32mrig config get <key>\u{1b}[39m to see the value of an entry, and\n  \u{1b}[32mrig config set <key>=<value>\u{1b}[39m to change it.";
const ABOUT_CONFIG_SET: &str = "Set a config entry";
const HELP_CONFIG_SET: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Set a rig configuration entry.\n\n  The argument is a \u{1b}[32mkey=value\u{1b}[39m pair, e.g. \u{1b}[32mrig config set mode=user\u{1b}[39m. The\n  configuration file is created if it does not exist yet. Use\n  \u{1b}[32mrig config list\u{1b}[39m to see the available keys.";
const ABOUT_CONFIG: &str = "Manage rig configuration";
const HELP_CONFIG: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Manage the rig configuration file.\n\n  rig reads a number of settings from a configuration file, e.g. the\n  installation \u{1b}[32mmode\u{1b}[39m (user or admin), the quick-link directory\n  (\u{1b}[32mbinary-dir\u{1b}[39m) and the R installation root (\u{1b}[32mr-install-dir\u{1b}[39m). Most\n  settings can also be overridden with environment variables.\n\n  \u{1b}[32mrig config config-file-path\u{1b}[39m prints the path to the config file.\n  \u{1b}[32mrig config list\u{1b}[39m lists the names of all configuration entries.\n  \u{1b}[32mrig config get\u{1b}[39m prints the value of a configuration entry.\n  \u{1b}[32mrig config set\u{1b}[39m sets a configuration entry.";
const ABOUT_DEFAULT: &str = "Print or set default R version [alias: switch]";
const HELP_DEFAULT: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Print or set the default R version. The default R version is the one that\n  is started with the \u{1b}[32mR\u{1b}[39m command, via the \u{1b}[32mR\u{1b}[39m quick link in the rig binary\n  directory (\u{1b}[32m~/.local/bin\u{1b}[39m in user mode).\n\n  Call without any arguments to see the current default. Call with the\n  version number/name to set the default. Before setting a default, you\n  can call \u{1b}[32mrig list\u{1b}[39m to see the installed R versions.\n\n  The default R version is set by updating the \u{1b}[32mcurrent\u{1b}[39m symbolic link in\n  the R installation directory and pointing it to the specified R version.\n\n  In user mode rig works entirely within your home directory, so no \u{1b}[32msudo\u{1b}[39m\n  is needed. In admin mode this command can change the default version\n  without \u{1b}[32msudo\u{1b}[39m as long as the user is in the \u{1b}[32madmin\u{1b}[39m group; otherwise you\n  need to run it as \u{1b}[32msudo rig default ...\u{1b}[39m.\n\n  You don't need to update the default R version to just run a non-default R\n  version. You can use the \u{1b}[32mR-<ver>\u{1b}[39m links, see \u{1b}[32mrig system make-links\u{1b}[39m.\n\n  \u{1b}[32mrig switch\u{1b}[39m is an alias of \u{1b}[32mrig default\u{1b}[39m.\n\n\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  # Query default R version\n  rig default\n\n  # Set the default version\n  rig default 4.1.2";
const HELP_EXAMPLES: &str = "\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  # Add the latest development snapshot\n  rig add devel\n\n  # Add the latest release\n  rig add release\n\n  # Install specific version\n  rig add 4.1.2\n\n  # Install latest version within a minor branch\n  rig add 4.1\n\n  # List installed versions\n  rig list\n\n  # Set default version\n  rig default 4.1.2";
const ABOUT_LIBRARY_ADD: &str = "Add a new library";
const HELP_LIBRARY_ADD: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Add a new user package library for the current R version.\n\n  The new library is created empty. Adding a library does not change the\n  default library; use \u{1b}[32mrig library default\u{1b}[39m to switch to it. No\n  administrator rights are needed.";
const ABOUT_LIBRARY_DEFAULT: &str = "Set the default library";
const HELP_LIBRARY_DEFAULT: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Show or set the default package library for the current R version.\n\n  Call without arguments to print the current default library. Call with a\n  library name to make it the default. New R sessions of the current R\n  version will then use that library.";
const ABOUT_LIBRARY_LIST: &str = "List libraries [alias: ls]";
const HELP_LIBRARY_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List the package libraries of the current R version [alias: ls].\n\n  The default library is marked. See \u{1b}[32mrig library\u{1b}[39m for an overview of user\n  package libraries.";
const ABOUT_LIBRARY_RM: &str = "Remove a library";
const HELP_LIBRARY_RM: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Remove a user package library of the current R version, including all\n  packages installed in it.\n\n  You cannot remove the current default library, and you cannot remove the\n  main library. Switch to another library with \u{1b}[32mrig library default\u{1b}[39m first\n  if needed.";
const ABOUT_LIBRARY: &str = "Manage package libraries [alias: lib] (experimental)";
const HELP_LIBRARY: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Manage package libraries [alias: lib] (experimental)\n\n  rig supports multiple user package libraries. The usual user library is\n  called \"main\".\n\n  \u{1b}[32mrig library default\u{1b}[39m shows or sets the default library for the\n  current R version.\n  \u{1b}[32mrig library list\u{1b}[39m lists all libraries for the current R version.\n  \u{1b}[32mrig library add\u{1b}[39m adds a new library for the current R version.\n  \u{1b}[32mrig library rm\u{1b}[39m deletes a library, including all packages in it.\n  It is not possible to delete the current default library, and it is not\n  possible to delete the main library.\n\n  User libraries are implemented at the user level, no administrator or\n  root password is needed to add, set or delete them. If you delete an\n  R installation, the user package libraries and their configurations are\n  kept for all users on the system.\n\n  \u{1b}[32mrig library\u{1b}[39m is currently experimental, and might change in future\n  versions. Feedback is appreciated.";
const ABOUT_LIST: &str = "List installed R versions [alias: ls]";
const HELP_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List installed R versions. It does \u{1b}[3mnot\u{1b}[23m check if they are working\n  properly.\n\n  \u{1b}[32mrig ls\u{1b}[39m is an alias.";
const ABOUT_PROJ_DEPLOY: &str = "Deploy project dependencies";
const HELP_PROJ_DEPLOY: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Install the resolved dependencies of an R project into a package library.\n\n  rig solves the project dependencies and installs them into the library\n  given by \u{1b}[32m--library\u{1b}[39m. Use \u{1b}[32m--r-binary\u{1b}[39m to select which R to build against\n  (default: \u{1b}[32mR\u{1b}[39m) and \u{1b}[32m--max-concurrent\u{1b}[39m to limit the number of simultaneous\n  installations (default: 4).";
const ABOUT_PROJ_DEPS: &str = "Show project dependencies";
const HELP_PROJ_DEPS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Show the dependencies of an R project.\n\n  By default rig reads the project manifest (e.g. \u{1b}[32mDESCRIPTION\u{1b}[39m) in the\n  current directory; use \u{1b}[32m--input\u{1b}[39m to point to a different file. Add \u{1b}[32m--dev\u{1b}[39m\n  to include development dependencies.";
const ABOUT_PROJ_SOLVE: &str = "Solve project dependencies";
const HELP_PROJ_SOLVE: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Resolve the dependencies of an R project to a concrete set of package\n  versions.\n\n  rig reads the project manifest (e.g. \u{1b}[32mDESCRIPTION\u{1b}[39m; override with\n  \u{1b}[32m--input\u{1b}[39m) and uses its built-in solver to find a compatible set of\n  package versions from the configured repositories, without running R.\n\n  Use \u{1b}[32m--r-version\u{1b}[39m to solve for a specific R version, \u{1b}[32m--dev\u{1b}[39m to include\n  development dependencies, and \u{1b}[32m--renv\u{1b}[39m to write the result as an\n  \u{1b}[32mrenv.lock\u{1b}[39m file.";
const ABOUT_PROJ: &str = "Manage R projects (experimental)";
const HELP_PROJ: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Manage R projects (experimental).\n\n  A project is a directory with a package manifest, typically a\n  \u{1b}[32mDESCRIPTION\u{1b}[39m file, that declares the R packages the project depends on.\n  \u{1b}[32mrig proj\u{1b}[39m resolves those dependencies against the configured package\n  repositories and can install them into a project library.\n\n  \u{1b}[32mrig proj deps\u{1b}[39m shows the direct and recursive dependencies of the\n  project.\n  \u{1b}[32mrig proj solve\u{1b}[39m resolves the full dependency tree to a concrete set of\n  package versions, and can write the result to an \u{1b}[32mrenv.lock\u{1b}[39m file.\n  \u{1b}[32mrig proj deploy\u{1b}[39m installs the resolved dependencies into a package\n  library.\n\n  Dependencies are resolved with rig's built-in solver, so R does not need\n  to be running for \u{1b}[32mrig proj deps\u{1b}[39m and \u{1b}[32mrig proj solve\u{1b}[39m.\n\n  \u{1b}[32mrig proj\u{1b}[39m is currently experimental, and might change in future\n  versions. Feedback is appreciated.";
const ABOUT_REPOS_AVAILABLE: &str = "List available R package repositories";
const HELP_REPOS_AVAILABLE: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List the package repositories that rig knows about and can set up.\n\n  These are the repositories you can enable with \u{1b}[32m--with-repos\u{1b}[39m when running\n  \u{1b}[32mrig add\u{1b}[39m or \u{1b}[32mrig repos setup\u{1b}[39m.";
const ABOUT_REPOS_LIST: &str = "List configured R package repositories";
const HELP_REPOS_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List the package repositories configured for an R version.\n\n  By default rig shows the repositories of the default R version; use\n  \u{1b}[32m--r-version\u{1b}[39m to pick another. Add \u{1b}[32m--all\u{1b}[39m to include repositories that\n  are not enabled by default, and \u{1b}[32m--raw\u{1b}[39m to show repository URLs without\n  resolving the \u{1b}[32m%\u{1b}[39m variables in them.";
const ABOUT_REPOS_PACKAGE_INFO: &str = "Information about the package in the repositories";
const HELP_REPOS_PACKAGE_INFO: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Show information about a package in the configured repositories.\n\n  By default the latest available version is shown; use \u{1b}[32m--version\u{1b}[39m to\n  select a specific one.";
const ABOUT_REPOS_PACKAGE_LIST: &str = "List packages in R package repositories";
const HELP_REPOS_PACKAGE_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List the packages available from the configured package repositories.\n\n  By default rig uses the default R version and the current platform;\n  override these with \u{1b}[32m--r-version\u{1b}[39m, \u{1b}[32m--platform\u{1b}[39m and \u{1b}[32m--pkg-type\u{1b}[39m (e.g.\n  \u{1b}[32msource\u{1b}[39m or \u{1b}[32mbinary\u{1b}[39m).";
const ABOUT_REPOS_PACKAGE_VERSIONS: &str = "List all versions of a package in the repositories";
const HELP_REPOS_PACKAGE_VERSIONS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List all versions of a package known to the CRAN metadata database,\n  oldest first. For each version rig shows its publication date, its R\n  version requirement and its number of hard dependencies (\u{1b}[32mDepends\u{1b}[39m,\n  \u{1b}[32mImports\u{1b}[39m and \u{1b}[32mLinkingTo\u{1b}[39m, excluding R and the base packages); the\n  latest version is marked.\n\n  Use \u{1b}[32m--json\u{1b}[39m to print the full crandb record for every version,\n  including the complete metadata and dependency lists. See\n  \u{1b}[32mrig repos package-info\u{1b}[39m for a detailed view\n  of a single version.";
const ABOUT_REPOS_SETUP: &str = "Set up R package repositories";
const HELP_REPOS_SETUP: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Set up the package repositories for installed R versions.\n\n  By default rig configures the repositories for all installed R versions;\n  use \u{1b}[32m--r-version\u{1b}[39m to restrict it to one. Use \u{1b}[32m--with-repos\u{1b}[39m and\n  \u{1b}[32m--without-repos\u{1b}[39m to control which repositories are enabled, the same way\n  as for \u{1b}[32mrig add\u{1b}[39m.";
const ABOUT_REPOS: &str = "Manage package repositories";
const HELP_REPOS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Manage the R package repositories that rig configures for your R\n  installations.\n\n  rig sets up the repositories R uses to install packages (the \u{1b}[32mrepos\u{1b}[39m\n  option in R), typically a CRAN mirror and the Posit Public Package\n  Manager (P3M). These are configured per R version, and you can control\n  them when installing R (see the \u{1b}[32m--with-repos\u{1b}[39m and \u{1b}[32m--without-repos\u{1b}[39m\n  options of \u{1b}[32mrig add\u{1b}[39m) or afterwards with the subcommands here.\n\n  \u{1b}[32mrig repos setup\u{1b}[39m (re)configures the repositories for one or all R\n  versions.\n  \u{1b}[32mrig repos list\u{1b}[39m shows the repositories currently configured for an R\n  version.\n  \u{1b}[32mrig repos available\u{1b}[39m lists the repositories rig knows about and can set\n  up.\n  \u{1b}[32mrig repos package-list\u{1b}[39m lists the packages available from the\n  configured repositories.";
const ABOUT_RESOLVE: &str = "Resolve a symbolic R version";
const HELP_RESOLVE: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Resolve R versions. Checks the version number of an R version (e.g.\n  release, devel, etc.), and looks up the URL of the installer for it,\n  if an installer is available.\n\n  It prints the R version number, and after a space the URL of the\n  installer. If no installer is available for this R version and the\n  current platform, the URL is \u{1b}[32mNA\u{1b}[39m.\n\n  An R version can be specified in various ways:\n\n  - \u{1b}[32mrig resolve devel\u{1b}[39m is the latest available development version,\n  - \u{1b}[32mrig resolve next\u{1b}[39m is the next (patched, alpha, beta, etc.) version,\n  - \u{1b}[32mrig resolve release\u{1b}[39m is the latest release.\n  - \u{1b}[32mrig resolve x.y.z\u{1b}[39m is a specific version.\n  - \u{1b}[32mrig resolve x.y\u{1b}[39m is the latest release within the \u{1b}[32mx.y\u{1b}[39m minor branch.\n  - \u{1b}[32mrig resolve oldrel/n\u{1b}[39m is the latest release within the \u{1b}[32mn\u{1b}[39mth previous\n    minor branch (\u{1b}[32moldrel\u{1b}[39m is the same as \u{1b}[32moldrel/1\u{1b}[39m).\n\n\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  # Latest development snapshot\n  rig resolve devel\n\n  # Latest release (that has an installer available)\n  rig resolve release\n\n  # URL for a specific version\n  rig resolve 4.1.2\n\n  # Latest version within a minor branch\n  rig resolve 4.1";
const ABOUT_RM: &str = "Remove R versions [aliases: del, remove, delete]";
const HELP_RM: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Remove an R installation. It keeps the users' package libraries.\n\n  In user mode no administrator rights are needed. In admin mode you need\n  an administrator account to run this command or use \u{1b}[32msudo\u{1b}[39m on Unix,\n  otherwise rig will ask for your password.";
const ABOUT_RSTUDIO: &str = "Start RStudio with specified R version";
const HELP_RSTUDIO: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Start RStudio with the specified R version.\n\n  If \u{1b}[32mproject-file\u{1b}[39m is an RStudio \u{1b}[32m.Rproj\u{1b}[39m file, or a directory containing\n  an RStudio project file, RStudio will open the project.\n\n  If \u{1b}[32mproject-file\u{1b}[39m is a directory that does not contain an RStudio\n  project file, then RStudio will start up without an active project,\n  but will set the working directory to the specified directory.\n\n  If \u{1b}[32mproject-file\u{1b}[39m is a regular file that is not inside a directory\n  containing an RStudio project, then RStudio will start up without an\n  active project, but it will open the specified file, and will set the\n  working directory to the directory of the file.\n\n  If the RStudio project or the specified directory contains an \u{1b}[32mrenv.lock\u{1b}[39m\n  file (created by the renv package), and \u{1b}[32mversion\u{1b}[39m is not specified, then\n  rig will read the preferred R version from the \u{1b}[32mrenv.lock\u{1b}[39m file.\n  If the same exact version is not installed, then rig chooses\n  the latest version with the same major and minor components. If no such\n  version is available, rig throws an error.\n\n  On macOS arm64 computers rig prefers arm64 R, unless an exact version\n  match is only available with x86_64 R.\n\n  On Windows, \u{1b}[32mrig rstudio\u{1b}[39m needs RStudio Desktop 2021.09.0+351 or later.\n\n\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  # With default R version\n  rig rstudio\n\n  # With another R version\n  rig rstudio 4.6\n\n  # Open project with default R version\n  rig rstudio cli.Rproj\n\n  # Open renv project with the R version specified in the lock file\n  rig rstudio projects/myproject/renv.lock\n\n  # Open RStudio project with specified R version, either is good\n  rig rstudio 4.6 cli.Rproj\n  rig rstudio cli.Rproj 4.0";
const ABOUT_RTOOLS_ADD: &str = "Install new Rtools version [alias: install]";
const HELP_RTOOLS_ADD: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Install new Rtools versions on Windows.\n\n  You can specify the new version(s) by their name, optionally with an\n  'rtools' prefix, e.g. '43' or 'rtools43'.\n\n  If \u{1b}[32mversion\u{1b}[39m is 'all' (the default), then all Rtools versions that are\n  required for the currently installed R versions will be installed.\n\n  In user mode (\u{1b}[32mRIG_MODE=user\u{1b}[39m) Rtools is installed per-user, without\n  administrator rights, into \u{1b}[32m%APPDATA%\\rig\\data\\rtools\u{1b}[39m (override with the\n  \u{1b}[32mRIG_RTOOLS_INSTALL_DIR\u{1b}[39m environment variable or the \u{1b}[32mrtools-install-dir\u{1b}[39m\n  config setting). rig points each R version at it by setting \u{1b}[32mRTOOLS<ver>_HOME\u{1b}[39m\n  in that R version's \u{1b}[32metc\\Renviron.site\u{1b}[39m.\n\n  In admin mode this command needs an administrator account.\n\n\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  rig rtools add 43\n  rig rtools add all";
const ABOUT_RTOOLS_LIST: &str = "List installed Rtools versions [alias: ls]";
const HELP_RTOOLS_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List installed Rtools versions on Windows.\n\n  It only lists versions that are added to the Windows Registry.\n\n  Use the \u{1b}[32m--json\u{1b}[39m flag for JSON output.";
const ABOUT_RTOOLS_RM: &str = "Remove rtools versions [aliases: del, remove, delete]";
const HELP_RTOOLS_RM: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Remove Rtools versions on Windows.\n\n  You can specify the version(s) to remove by their name, optionally with\n  an 'rtools' prefix, e.g. '43' or 'rtools43'.\n\n  If no version is specified, then it does nothing.\n\n  In admin mode this command needs an administrator account.\n\n\u{1b}[1m\u{1b}[34mExamples:\u{1b}[39m\u{1b}[22m\n  rig rtools rm 43";
const ABOUT_RTOOLS: &str = "Manage Rtools installations";
const HELP_RTOOLS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Manage Rtools installations (Windows only).\n\n  Rtools is the collection of build tools (compilers, \u{1b}[32mmake\u{1b}[39m, etc.) needed\n  to build R packages from source on Windows. Each R version needs a\n  matching Rtools version.\n\n  \u{1b}[32mrig rtools list\u{1b}[39m lists the installed Rtools versions.\n  \u{1b}[32mrig rtools add\u{1b}[39m installs Rtools, by default every version needed by the\n  currently installed R versions.\n  \u{1b}[32mrig rtools rm\u{1b}[39m removes Rtools versions.\n\n  On non-Windows platforms this command does nothing and is hidden.";
const ABOUT_RUN: &str = "Run R, an R script or an R project";
const HELP_RUN: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Run R, an R script or an R project, using the selected R version.\n\n  All of these examples allow an \u{1b}[32m--r-version\u{1b}[39m argument, to use a specific\n  R version.\n\n  rig run                    # start R\n  rig run -f <script-file>   # run an R script\n  rig run -e <expression>    # evaluate an R expression\n  rig run <pkg>::<script>    # run a script from a package's exec directory\n  rig run <path-to-app>      # run an R app\n\n  Currently supported apps are:\n\n  - Plumber APIs,\n  - Shiny apps,\n  - Quarto documents embedding Shiny apps,\n  - Quarto documents,\n  - Rmd documents,\n  - Rmd documents embedding Shiny apps,\n  - Static web sites.";
const ABOUT_SYSREQS_ADD: &str = "Install system library or tool";
const HELP_SYSREQS_ADD: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Install a system library or tool that R packages need to build or run\n  (experimental, macOS only).\n\n  Specify one or more tool names; see \u{1b}[32mrig sysreqs list\u{1b}[39m for the available\n  ones. Use \u{1b}[32m--arch\u{1b}[39m to install for a specific architecture; by default the\n  native architecture is used.";
const ABOUT_SYSREQS_INFO: &str = "Information about a system tool";
const HELP_SYSREQS_INFO: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Show information about a system library or tool (experimental, macOS\n  only).\n\n  Prints details of the named tool, e.g. its version and whether it is\n  installed. Use \u{1b}[32mrig sysreqs list\u{1b}[39m to see the available tool names.";
const ABOUT_SYSREQS_LIST: &str = "List available system libraries and tools";
const HELP_SYSREQS_LIST: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  List the system libraries and tools that rig can install (experimental,\n  macOS only).\n\n  See \u{1b}[32mrig sysreqs info <name>\u{1b}[39m for details about a specific tool, and\n  \u{1b}[32mrig sysreqs add <name>\u{1b}[39m to install one.";
const ABOUT_SYSREQS: &str = "Manage R-related system libraries and tools (experimental)";
const HELP_SYSREQS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Manage system libraries and tools. This currently includes a very\n  restricted set of tools, that are needed for running \u{1b}[32mR CMD check\u{1b}[39m.\n  Run \u{1b}[32mrig sysreqs list\u{1b}[39m for a complete list.";
const ABOUT_SYSTEM_ADD_PAK: &str = "Install or update pak for an R version";
const HELP_SYSTEM_ADD_PAK: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Install/update pak for one or more R versions.\n\n  - If \u{1b}[32m--all\u{1b}[39m is specified, then it installs pak for all current R\n    installations.\n  - If one or more R versions are specified, then it installs pak for\n    those.\n  - If no R versions are specified, then it installs pak for the default\n    R installation, if there is one (see \u{1b}[32mrig default\u{1b}[39m).";
const ABOUT_SYSTEM_ALLOW_CORE_DUMPS: &str = "Allow creating core dumps when R crashes";
const HELP_SYSTEM_ALLOW_CORE_DUMPS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Update the entitlements of the R process to allow core dumps on macOS.\n  This command is similar to \u{1b}[32mrig system allow-debugger\u{1b}[39m but it also makes\n  sure that the \u{1b}[32m/cores\u{1b}[39m directory of core dumps is writeable by the\n  current user. Don't forget to call \u{1b}[32mulimit -c unlimited\u{1b}[39m from the\n  same shell before starting R.\n\n  This command does nothing on Windows and Linux and in user mode.\n\n  In admin mode this command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system allow-core-dumps\u{1b}[39m, otherwise rig will ask for your\n  password.";
const ABOUT_SYSTEM_ALLOW_DEBUGGER_RSTUDIO: &str = "Allow debugging RStudio with lldb and gdb";
const HELP_SYSTEM_ALLOW_DEBUGGER_RSTUDIO: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Update the entitlements of RStudio R process to allow debuggers on macOS.\n  It adds the \u{1b}[32mget-task-allow\u{1b}[39m entitlement to the \u{1b}[32mrsession\u{1b}[39m (and\n  \u{1b}[32mrsession-arm64\u{1b}[39m on arm64 hardware) binary.\n\n  See also \u{1b}[32mrig system allow-debugger\u{1b}[39m, which does the same for\n  R running outside of RStudio.\n\n  This command does nothing on Windows and Linux.\n\n  This command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system allow-debugger-rstudio\u{1b}[39m, otherwise rig will ask for your\n  password.";
const ABOUT_SYSTEM_ALLOW_DEBUGGER: &str = "Allow debugging R with lldb and gdb";
const HELP_SYSTEM_ALLOW_DEBUGGER: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Update the entitlements of the R binary to allow debuggers on macOS. It\n  adds the \u{1b}[32mget-task-allow\u{1b}[39m entitlement to the R binary. This is only\n  needed for R installers 3.6 and later, previous versions are not signed.\n  Call \u{1b}[32mR -d lldb\u{1b}[39m to start \u{1b}[32mlldb\u{1b}[39m on \u{1b}[32mR\u{1b}[39m. (Or \u{1b}[32mR-x.y -d lldb\u{1b}[39m if you\n  want a non-default version.)\n\n  See also \u{1b}[32mrig system allow-debugger-rstudio\u{1b}[39m, which does the same for\n  R running in RStudio.\n\n  This command does nothing on Windows and Linux and in user mode.\n\n  In admin mode this command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system allow-debugger\u{1b}[39m, otherwise rig will ask for your\n  password.";
const ABOUT_SYSTEM_CLEAN_ADMIN_R: &str = "Remove all admin-mode R installations and links";
const HELP_SYSTEM_CLEAN_ADMIN_R: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Remove all admin-mode R installations and their quick links.\n\n  This is an internal helper used by \u{1b}[32mrig system user-mode\u{1b}[39m to clean up a\n  previous admin-mode setup. It self-escalates to obtain the required\n  administrator rights, so you normally do not need to run it directly.\n\n  Use \u{1b}[32m--keep-install\u{1b}[39m to keep the R installations and \u{1b}[32m--keep-links\u{1b}[39m to\n  keep the quick links.";
const ABOUT_SYSTEM_CLEAN_REGISTRY: &str = "Clean stale R related entries in the registry";
const HELP_SYSTEM_CLEAN_REGISTRY: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Remove R and Rtools entries from the Windows registry, if the\n  corresponding R or Rtools versions are not installed any more.\n\n  This command does nothing on macOS and Linux.";
const ABOUT_SYSTEM_DETECT_PLATFORM: &str = "Detect operating system version and distribution.";
const HELP_SYSTEM_DETECT_PLATFORM: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Detect and print the operating system version and distribution.\n\n  rig uses this information to choose the right R builds and package\n  repositories. Use \u{1b}[32m--json\u{1b}[39m for machine-readable output.";
const ABOUT_SYSTEM_FIX_PERMISSIONS: &str = "Restrict system library permissions to admin";
const HELP_SYSTEM_FIX_PERMISSIONS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Update the permissions of the current R versions on macOS, so only the\n  administrator can install R packages into the system library.\n  Together with \u{1b}[32mrig system create-lib\u{1b}[39m this facilitates keeping\n  additional packages in a user library, instead of the system library.\n\n  This command does nothing on Windows and Linux and in user mode.\n\n  \u{1b}[32mrig add\u{1b}[39m runs \u{1b}[32mrig system fix-permissions\u{1b}[39m, so if you only use rig to\n  install R, then you do not need to run it manually.\n\n  In admin mode this command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system fix-permissions\u{1b}[39m, otherwise rig will ask for your\n  password.";
const ABOUT_SYSTEM_FIX_R_ALIAS: &str = "Make the 'R' command start R in PowerShell";
const HELP_SYSTEM_FIX_R_ALIAS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Make the 'R' command start R in PowerShell.\n\n  PowerShell ships a built-in 'r' alias for 'Invoke-History', and because\n  aliases take precedence over external commands, typing 'R' reruns the\n  previous command instead of starting R. This command removes that alias\n  in your PowerShell profile so that 'R' starts R via rig's quick link.\n\n  It edits the 'CurrentUserAllHosts' profile of every PowerShell it finds\n  (both 'pwsh' and 'powershell'), in an idempotent, clearly marked block.\n  Start a new PowerShell session for the change to take effect.\n\n  Use the '--undo' flag to remove the block rig added, leaving the rest of\n  the PowerShell profile(s) untouched.\n\n  This command does nothing on macOS and Linux.";
const ABOUT_SYSTEM_FORGET: &str = "Make system forget about R installations";
const HELP_SYSTEM_FORGET: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Tell macOS to forget about the currently installed R versions.\n  This is needed to have multiple R installations at the same time.\n\n  This command does nothing on Windows and Linux and in user mode.\n\n  \u{1b}[32mrig add\u{1b}[39m runs \u{1b}[32mrig system forget\u{1b}[39m before and after the installation,\n  so if you only use rig to install R, then you don't need to run this\n  command manually.\n\n  In admin mode this command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system forget\u{1b}[39m, otherwise rig will ask for your password.";
const ABOUT_SYSTEM_MAKE_LINKS: &str = "Create R-* quick links";
const HELP_SYSTEM_MAKE_LINKS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Create quick links in the rig binary directory (\u{1b}[32m~/.local/bin\u{1b}[39m in user\n  mode) for the current R installations. These let you directly run a\n  specific R version. E.g. \u{1b}[32mR-4.6.0\u{1b}[39m will start R 4.6.0. It also creates\n  the \u{1b}[32mR\u{1b}[39m and \u{1b}[32mRscript\u{1b}[39m links if they are missing.\n\n  \u{1b}[32mrig add\u{1b}[39m runs \u{1b}[32mrig system make-links\u{1b}[39m, so if you only use rig to\n  install R, then you do not need to run it manually.\n\n  In user mode no administrator rights are needed. In admin mode you need\n  an administrator account to run this command or use \u{1b}[32msudo\u{1b}[39m on Unix,\n  otherwise rig will ask for your password.";
const ABOUT_SYSTEM_MAKE_ORTHOGONAL: &str = "Make installed versions orthogonal";
const HELP_SYSTEM_MAKE_ORTHOGONAL: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Make the current R installations orthogonal on macOS. This allows\n  running multiple R versions at the same time.\n\n  This command does nothing on Windows and Linux, where R installations\n  are automatically orthogonal. It also does nothing in user mode, as user\n  mode installations are always orthogonal.\n\n  \u{1b}[32mrig add\u{1b}[39m runs \u{1b}[32mrig system make-orthogonal\u{1b}[39m automatically, you do not\n  need to run it manually.\n\n  In admin mode this command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system make-orthogonal\u{1b}[39m, otherwise rig will ask for your\n  password.";
const ABOUT_SYSTEM_NO_OPENMP: &str = "Remove OpenMP (-fopenmp) option for Apple compilers";
const HELP_SYSTEM_NO_OPENMP: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Remove -fopenmp flags from the R configuration, to make R work with\n  the Apple compilers, instead of CRAN's custom compilers. This is only\n  needed for R 3.6.x and before.\n\n  \u{1b}[32mrig add\u{1b}[39m runs \u{1b}[32mrig system no-openmp\u{1b}[39m after the installation, so if\n  only use rig to install R, then you don't need to run this command\n  manually.\n\n  This command does nothing on Windows and Linux and in user mode.\n\n  In admin mode this command probably needs \u{1b}[32msudo\u{1b}[39m:\n  \u{1b}[32msudo rig system no-openmp\u{1b}[39m, otherwise rig will ask for your password.";
const ABOUT_SYSTEM_SETUP_USER_LIB: &str = "Set up automatic user package libraries [alias: create-lib]";
const HELP_SYSTEM_SETUP_USER_LIB: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Set up R to create user package libraries when started, by default for\n  installed R versions.\n\n  \u{1b}[32mrig add\u{1b}[39m runs \u{1b}[32mrig system create-lib\u{1b}[39m, so if you only use rig to\n  install R, then you do not need to run it manually.";
const ABOUT_SYSTEM_UPDATE_CERTS: &str = "Download the CA certificate bundle and configure R to use it";
const HELP_SYSTEM_UPDATE_CERTS: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Download the CA certificate bundle and configure R to use it (Linux\n  only).\n\n  This helps R make HTTPS connections on systems where the default\n  certificate store is missing or out of date.";
const ABOUT_SYSTEM_UPDATE_RTOOLS40: &str = "Update Rtools40 MSYS2 packages";
const HELP_SYSTEM_UPDATE_RTOOLS40: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Update Rtools40 compilers and libraries to the latest builds by\n  updating the MSYS2 packages in Rtools40 on Windows.\n\n  This command does nothing on macOS and Linux.\n\n  In admin mode this command needs an administrator account.";
const ABOUT_SYSTEM_USER_MODE: &str = "Switch to user mode and clean up admin-mode installations";
const HELP_SYSTEM_USER_MODE: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Switch rig to user mode and clean up the machine after admin mode.\n\n  In user mode rig installs R into your home directory\n  (\u{1b}[32m~/.local/share/rig/r\u{1b}[39m or \u{1b}[32m%APPDATA%\\rig\\data\\r\u{1b}[39m on Windows),\n  and quick links into \u{1b}[32m~/.local/bin\u{1b}[39m, so that rig never needs \u{1b}[32msudo\u{1b}[39m.\n  This command migrates an existing admin-mode setup to user mode:\n\n  1. Sets the rig \u{1b}[32mmode\u{1b}[39m configuration to \u{1b}[32muser\u{1b}[39m.\n  2. Reinstalls the admin-mode R versions in user mode, and restores\n     the previous default version and version aliases. R versions that\n     are already installed in user mode are not reinstalled. Use\n     \u{1b}[32m--no-reinstall\u{1b}[39m to skip this step entirely and only clean up.\n  3. Removes the system-wide admin-mode R installations.\n  4. Removes the system-wide \u{1b}[32mR-*\u{1b}[39m quick links and the \u{1b}[32mR\u{1b}[39m/\u{1b}[32mRscript\u{1b}[39m\n     links.\n\n  Steps 3 and 4 remove files outside your home directory, so this command\n  needs an administrator account or \u{1b}[32msudo\u{1b}[39m on Unix, otherwise it will ask\n  for your password.\n\n  Use \u{1b}[32m--keep-install\u{1b}[39m to leave the admin-mode R installations in\n  in place (skipping step 3), and \u{1b}[32m--keep-links\u{1b}[39m to leave the system-wide\n  links in place (skipping step 4). With both, nothing outside your home\n  directory is touched and no administrator account or \u{1b}[32msudo\u{1b}[39m is needed.";
const ABOUT_SYSTEM: &str = "Manage current installations";
const HELP_SYSTEM: &str = "\u{1b}[1m\u{1b}[34mDescription:\u{1b}[39m\u{1b}[22m\n  Various commands to modify and configure the installed R versions.\n  See their help pages for details. E.g. run \u{1b}[32mrig system make-links --help\u{1b}[39m.";
